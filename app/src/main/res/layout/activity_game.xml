<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a1a"
    android:padding="16dp">

    <!-- Score Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#2a2a2a"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <!-- Human Score -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOU"
                android:textColor="#7CFC00"
                android:textStyle="bold"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/humanTotalScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#ffffff"
                android:textSize="36sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/humanTurnInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Brains: 0  Shotguns: 0"
                android:textColor="#aaaaaa"
                android:textSize="12sp"/>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#555555"/>

        <!-- AI Score -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ZOMBIE AI"
                android:textColor="#cc0000"
                android:textStyle="bold"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/aiTotalScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#ffffff"
                android:textSize="36sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/aiTurnInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Brains: 0  Shotguns: 0"
                android:textColor="#aaaaaa"
                android:textSize="12sp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Status Message -->
    <TextView
        android:id="@+id/statusMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Press Roll to start!"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="12dp"
        android:background="#2a2a2a"
        android:layout_marginBottom="16dp"/>

    <!-- Dice Display Area -->
    <LinearLayout
        android:id="@+id/diceContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/die1"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_margin="8dp"
            android:src="@android:drawable/ic_menu_help"
            android:contentDescription="Die 1"/>

        <ImageView
            android:id="@+id/die2"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_margin="8dp"
            android:src="@android:drawable/ic_menu_help"
            android:contentDescription="Die 2"/>

        <ImageView
            android:id="@+id/die3"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_margin="8dp"
            android:src="@android:drawable/ic_menu_help"
            android:contentDescription="Die 3"/>

    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/rollButton"
            android:layout_width="140dp"
            android:layout_height="56dp"
            android:text="ROLL"
            android:textSize="18sp"
            android:backgroundTint="#7CFC00"
            android:textColor="#1a1a1a"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/bankButton"
            android:layout_width="140dp"
            android:layout_height="56dp"
            android:text="BANK"
            android:textSize="18sp"
            android:backgroundTint="#cc0000"
            android:textColor="#ffffff"/>

    </LinearLayout>

</LinearLayout>